{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/compscirunner/crimp/schema/manifest.schema.json",
  "title": "Crimp Hardware Manifest",
  "description": "AI-authored hardware manifest for a maker/robotics project. Humans do not edit this file directly — it is generated and maintained by an AI assistant.",
  "type": "object",
  "required": ["crimp_version", "project", "components", "connections"],
  "properties": {

    "crimp_version": {
      "description": "Schema version this manifest targets.",
      "type": "string",
      "examples": ["0.1.0"]
    },

    "project": {
      "description": "Top-level project metadata.",
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name":        { "type": "string" },
        "description": { "type": "string" },
        "revision":    { "type": "string" },
        "notes":       { "type": "string" }
      }
    },

    "wire_standards": {
      "description": "Named wire specs reused across connections. Avoids repeating gauge/color inline on every connection.",
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["gauge_awg", "color"],
        "properties": {
          "gauge_awg": { "type": "integer" },
          "color":     { "type": "string" },
          "notes":     { "type": "string" }
        }
      }
    },

    "power_rails": {
      "description": "Named power rails referenced by connections and components.",
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["voltage_nominal"],
        "properties": {
          "voltage_nominal":  { "type": "number" },
          "source_component": { "type": "string" },
          "max_current_a":    { "type": "number" },
          "notes":            { "type": "string" }
        }
      }
    },

    "components": {
      "description": "Every board, module, and device in the project, keyed by a stable identifier.",
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["name", "type", "pins"],
        "properties": {
          "name":          { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["mcu", "sensor", "actuator", "motor_controller", "power", "relay", "passive", "connector", "radio", "computer", "other"]
          },
          "description":   { "type": "string" },
          "datasheet_url": { "type": "string" },
          "voltage_logic": { "type": "number", "description": "Logic voltage level in volts, e.g. 3.3 or 5.0" },
          "notes":         { "type": "string" },
          "connector": {
            "description": "Physical connector type used to attach to this component.",
            "type": "object",
            "properties": {
              "type":      { "type": "string", "examples": ["JST-PH-4", "JST-XH-3", "Dupont-2.54-3", "XT60", "bare-wire", "screw-terminal"] },
              "position":  { "type": "string", "enum": ["component_side", "harness_side", "both", "none"] },
              "pin_order": { "type": "array", "items": { "type": "string" } }
            }
          },
          "pins": {
            "description": "All physical pins on this component, keyed by pin identifier (e.g. 'GP4', 'SDA', 'pin_1').",
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["function", "signal_type", "direction"],
              "properties": {
                "function":       { "type": "string", "description": "Human-readable pin function, e.g. 'I2C0 SDA', 'PWM output', '12V power in'" },
                "signal_type": {
                  "type": "string",
                  "enum": [
                    "power", "ground", "ac_power",
                    "digital_in", "digital_out",
                    "analog_in", "analog_out",
                    "i2c_sda", "i2c_scl",
                    "uart_tx", "uart_rx",
                    "pwm",
                    "spi_mosi", "spi_miso", "spi_clk", "spi_cs",
                    "usb", "ethernet",
                    "motor_power",
                    "nc_contact", "no_contact",
                    "reset",
                    "other", "nc"
                  ]
                },
                "direction":      { "type": "string", "enum": ["in", "out", "bidir", "power", "nc"] },
                "physical_label": { "type": "string", "description": "Label printed on the board, if any" },
                "voltage_rail":   { "type": "string", "description": "Reference to a power_rails entry" },
                "notes":          { "type": "string" }
              }
            }
          }
        }
      }
    },

    "connections": {
      "description": "Ordered list of individual wire runs. Each entry represents one physical wire between two component pins.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "from", "to", "wire"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable unique identifier for this connection. Used in test generation and diff output. e.g. 'enc1_sda', 'relay_in1'"
          },
          "label": {
            "type": "string",
            "description": "Human-readable signal name shown in the assembly guide and diagrams."
          },
          "from": {
            "type": "object",
            "required": ["component", "pin"],
            "properties": {
              "component": { "type": "string", "description": "Key into components" },
              "pin":       { "type": "string", "description": "Key into component.pins" }
            }
          },
          "to": {
            "type": "object",
            "required": ["component", "pin"],
            "properties": {
              "component": { "type": "string" },
              "pin":       { "type": "string" }
            }
          },
          "wire": {
            "type": "object",
            "description": "Physical wire specification for this run.",
            "properties": {
              "ref":        { "type": "string", "description": "Reference to a wire_standards entry. Overrides gauge_awg and color if set." },
              "gauge_awg":  { "type": "integer" },
              "color":      { "type": "string" },
              "length_mm":  { "type": "integer" },
              "notes":      { "type": "string" }
            }
          },
          "assembly_order": {
            "type": "integer",
            "description": "Explicit ordering for the assembly guide. AI should assign a safe build sequence (power before signal, GND before VCC)."
          },
          "commissioning": {
            "type": "object",
            "description": "Per-connection test specification. AI populates this; Crimp generates pytest stubs from it.",
            "properties": {
              "test_method": {
                "type": "string",
                "enum": ["continuity", "voltage", "i2c_scan", "uart_loopback", "gpio_toggle", "pwm_measure", "none"]
              },
              "expected_value": {},
              "tolerance":      {},
              "instrument": {
                "type": "string",
                "enum": ["multimeter", "oscilloscope", "software", "none"]
              },
              "notes": { "type": "string" }
            }
          },
          "notes": { "type": "string" }
        }
      }
    },

    "bom_overrides": {
      "description": "Manual BOM additions that don't appear as connections, e.g. pull-up resistors, heatshrink, mounting hardware.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "qty"],
        "properties": {
          "description":  { "type": "string" },
          "qty":          { "type": "integer" },
          "unit":         { "type": "string" },
          "source_notes": { "type": "string" }
        }
      }
    }

  }
}
